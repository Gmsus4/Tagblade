---
import { Image } from "astro:assets";
import FAQ from "../common/FAQ.astro";
import TitleSection from "../common/TitleSection.astro";
import { titles as data } from '../../js/titles';
---

<section class="md:px-20 sm:px-10 px-5 bg-background dark:bg-dark-background md:pb-20 pb-5" id="faqs" aria-label="Sección de preguntas frecuentes">
  <!-- Desktop -->
  <div class="max-w-screen-lg mx-auto md:px-4 px-1 lg:py-6 p-8 pb-4 md:grid grid-cols-7 gap-14 items-start pt-20 hidden w-full" data-aos="fade-down" data-aos-duration="800">
    <div class="col-span-7 grid gap-8">
      <TitleSection title={data.faqs.title} titleHeader={data.faqs.titleHeader}/>
      <div data-aos="fade-up" data-aos-duration="800" data-aos-delay="100">
        <FAQ />
      </div>
    </div>
  </div>

  <!-- Mobile -->
  <div class="col-span-7 2xl:col-span-4 px-2 grid gap-8 md:hidden">
    <div class="2xl:hidden flex" data-aos="fade-down" data-aos-duration="800">
      <TitleSection title={data.faqs.title} titleHeader={data.faqs.titleHeader}/>
    </div>
    <div data-aos="fade-up" data-aos-duration="800" data-aos-delay="100">
      <FAQ />
    </div>
  </div>
</section>