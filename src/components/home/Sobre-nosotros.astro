---
import { Image } from "astro:assets";
import { titles } from "../../js/titles";
import Team from "../common/Team.astro";
import TitleSection from "../common/TitleSection.astro";
import Proceso from "./Proceso.astro";
---
<section id="about-us" class="md:px-20 sm:px-10 px-5 bg-background dark:bg-dark-background" aria-label="Sección Sobre Nosotros">
  <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute top-20 left-10 w-64 h-64 bg-primary-hover/5 dark:bg-surface/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-10 w-80 h-80 bg-primary-hover/5 dark:bg-surface/5 rounded-full blur-3xl"></div>
  </div>

  <div class="max-w-screen-lg mx-auto lg:py-16 py-12 relative z-10">
    <div data-aos="fade-down" data-aos-duration="800">
      <TitleSection title={titles.sobreNosotros.title} titleHeader={titles.sobreNosotros.titleHeader} isCenter={true}/>
    </div>

    <div class="grid gap-16 m-auto items-center mt-10" data-aos="fade-up" data-aos-duration="800" data-aos-delay="100">
      <div class="h-full z-10 relative">
        <div class="absolute -left-4 -top-4 w-24 h-24 bg-primary-hover/10 dark:bg-surface/10 rounded-full"></div>
        <div class="absolute -right-4 -bottom-4 w-24 h-24 bg-primary-hover/10 dark:bg-surface/10 rounded-full"></div>
        <Team />
      </div>
    </div>
    
    <!-- Historia, Método, Visión -->
    <div class="mt-6 grid grid-cols-12 items-center lg:gap-20 gap-0">
      <div class="divide-y divide-gray-200/60 dark:divide-gray-700/40 lg:col-span-8 col-span-12">
        <article class="py-4" data-aos="fade-up" data-aos-duration="700">
          <h3 class="text-text-dark dark:text-text-light font-bold text-2xl mb-4">Nuestra historia</h3>
          <p class="text-text-secundary dark:text-background/60 text-lg leading-relaxed max-w-2xl">
            Tagblade nació de una idea simple: construir sitios web con intención. Fernando Gómez convirtió esa idea en una forma de trabajo, donde la tecnología se combina con criterio, detalle y una visión clara de lo que cada proyecto necesita.
          </p>
        </article>

        <article class="py-4" data-aos="fade-up" data-aos-duration="700" data-aos-delay="100">
          <h3 class="text-text-dark dark:text-text-light font-bold text-2xl mb-4">Nuestro método</h3>
          <p class="text-text-secundary dark:text-background/60 text-lg leading-relaxed max-w-2xl">
            Cada proyecto comienza escuchando. Luego, estructuramos, diseñamos y construimos con una mentalidad orientada al usuario. No seguimos plantillas rígidas: creamos soluciones que se ajustan a cada caso.
          </p>
        </article>

        <article class="py-4" data-aos="fade-up" data-aos-duration="700" data-aos-delay="200">
          <h3 class="text-text-dark dark:text-text-light font-bold text-2xl mb-4">Mirando hacia adelante</h3>
          <p class="text-text-secundary dark:text-background/60 text-lg leading-relaxed max-w-2xl">
            No solo pensamos en lo que necesitas hoy. Pensamos en lo que vendrá después. Nuestro compromiso es crear soluciones que se mantengan útiles, flexibles y relevantes con el tiempo. Porque una buena web no solo lanza, evoluciona.
          </p>
        </article>
      </div>

      <div class="lg:col-span-4 col-span-12 grid place-items-center py-16 md:py-0 gap-6">
        <Image
          src={"/tagblade.jpg"}
          alt=""
          class="object-cover rounded-4xl md:w-full"
          width={200}
          height={200}
          loading="lazy"
          data-aos="fade-up" data-aos-duration="700" data-aos-delay="100"
        />
        <h3 class="text-4xl font-bold dark:text-white" data-aos="fade-up" data-aos-duration="700" data-aos-delay="100">Tagblade</h3>
      </div>
    </div>

    <!-- <div data-aos="fade-up" data-aos-duration="700" data-aos-delay="300">
      <Proceso />
    </div> -->
  </div>
</section>

<style>
  #about-us {
    overflow-x: clip;
  }
</style>