---
import { Image } from "astro:assets";
import Play from "../icons/Play.astro";
const {
  id,
  name,
  username,
  role,
  imageUrl,
  banner,
  song,
  songUrl,
  description,
  imageUrlHover,
  socials = [],
} = Astro.props;
---

<article
  class="relative inline-block group"
  aria-labelledby={`profile-${id}-name`}
  aria-describedby={`profile-${id}-role`}
>
  <div class="dark:bg-bg-surface/90 hover:dark:bg-bg-surface shadow-sm p-6 grid gap-4 rounded-2xl">
    <div class="flex items-end justify-between">

      <!-- Contenedor de imágenes con efecto hover -->
      <div class="relative w-[100px] h-[100px] shrink-0">
        <!-- Imagen normal -->
        <Image
          src={imageUrl}
          alt={`${name} avatar`}
          class="object-cover rounded-full absolute inset-0 w-full h-full transition-opacity duration-300 opacity-100 group-hover:opacity-0"
          width={100}
          height={100}
          loading="lazy"
        />
        <!-- Imagen hover -->
        {imageUrlHover && (
          <Image
            src={imageUrlHover}
            alt={`${name} avatar hover`}
            class="object-cover rounded-full absolute inset-0 w-full h-full transition-opacity duration-300 opacity-0 group-hover:opacity-100"
            width={100}
            height={100}
            loading="lazy"
          />
        )}
      </div>

      <div class="mb-0 pb-0 flex flex-col justify-between h-full">
        <div>
          <a href={songUrl} target="_blank" class="text-[10px] flex items-center gap-1 px-2 outline outline-dark-background/10 dark:outline-white/20 dark:text-white shadow-sm rounded-full max-w-[140px] overflow-hidden">
            <Play class="w-4 h-4"/>
            <span class="truncate">{song}</span>
          </a>
        </div>
        <div>
          {
            socials.length > 0 && (
              <nav aria-label={`Redes sociales de ${name}`} class="z-20">
                <div class="flex justify-end gap-2 flex-wrap">
                  {socials.map(
                    (social: {
                      icon: any;
                      url: string | URL | null | undefined;
                      name: string | null | undefined;
                    }) => {
                      const Icon = social.icon;
                      return (
                        <a
                          aria-label={`${social.name}`}
                          href={social.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          title={social.name}
                          class="w-8 h-8 bg-primary hover:bg-primary-bright dark:bg-primary-bright dark:hover:bg-primary rounded-lg flex items-center justify-center transition-all duration-200 hover:scale-110"
                        >
                          <Icon class="w-5 h-5 text-text-light dark:text-text-dark" />
                        </a>
                      );
                    },
                  )}
                </div>
              </nav>
            )
          }
        </div>
      </div>
    </div>

    <div>
      <p class="text-lg font-bold dark:text-text-light text-text-dark mb-1">{name}</p>
      <p class="text-sm dark:text-gray-300 text-text-dark mb-1">@{username} • {role}</p>
      <p class="text-sm dark:text-gray-500 text-text-dark/60 mb-1">{description}</p>
    </div>
  </div>
</article>